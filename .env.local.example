# ============================================================
# Our Lady of All Souls Parish — Variables de entorno
# Copiar a .env.local y rellenar con valores reales.
# .env.local NUNCA se sube a git.
# ============================================================

# --- Supabase (Dashboard → Project Settings → API) ---
# URL del proyecto (pública, va al browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# Anon/public key (pública; la seguridad real la dan las políticas RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- OpenAI Whisper (transcripción de voz, Fase 3) ---
# SERVER-ONLY: sin prefijo NEXT_PUBLIC_. Solo la usa /api/transcribe.
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# --- Sitio ---
# Requerido para redirects de auth (en producción: https://tudominio.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
